# Copy to .env and fill in values (never commit .env)

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

SECRET_KEY=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@helix.health
ADMIN_PASSWORD=change-me

# Comma-separated origins for CORS, or * to allow all
CORS_ORIGINS=*

UPLOAD_DIR=uploads
API_PREFIX=/api/v1

# Resend — completion reminder emails (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Helix Health <onboarding@helixhealth.app>
RESEND_ENABLED=false
ONBOARDING_PORTAL_URL=https://www.helixhealth.app/on-boarding/index.html
SEND_SUBMIT_CONFIRMATION=true
SEND_APPLICATION_STARTED_EMAIL=true
